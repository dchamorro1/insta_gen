# Copy to `.env` and fill in. Only OPENAI_API_KEY is required, and only when
# generating backgrounds (not when supplying your own with --background).

OPENAI_API_KEY=sk-...

# Optional overrides (defaults shown):
# INSTA_GEN_OPENAI_MODEL=dall-e-3     # image model
# INSTA_GEN_TEXT_MODEL=gpt-4o-mini    # chat model that writes the scene prompt
# INSTA_GEN_IMAGE_SIZE=1024x1024
# INSTA_GEN_FONT_SIZE=50
# INSTA_GEN_FONT_PATH=assets/AalmaghribiQuran.ttf
# INSTA_GEN_OUTPUT_DIR=generated_images
